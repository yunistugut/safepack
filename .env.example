# SafePackISG — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#   cp .env.example .env

# ─── Django ───────────────────────────────────────
SECRET_KEY="dal-sarkar-kartal-kalkar"
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Veritabanı ───────────────────────────────────
# Geliştirme: SQLite (varsayılan, DB_URL'yi yorum satırı bırakın)
# Üretim: PostgreSQL
# DATABASE_URL=postgres://kullanici:sifre@localhost:5432/safepackisg

# ─── E-posta ──────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Üretimde:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=info@safepackisg.com
EMAIL_HOST_PASSWORD=uygulama-sifresi-buraya
DEFAULT_FROM_EMAIL=SafePackISG <info@safepackisg.com>
CONTACT_EMAIL=info@safepackisg.com

# ─── Medya / Statik ───────────────────────────────
# Üretimde AWS S3 veya benzeri bir storage kullanılabilir
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=safepackisg-media

# ─── Site Bilgileri ───────────────────────────────
SITE_URL=https://www.safepackisg.com
SITE_NAME=SafePackISG
